modules = ["python-3.12", "web"]
entrypoint = "malde/app/server.py"
run = "python3 malde/app/server.py"

[env]
HOST = "0.0.0.0"
PORT = "8137"
# fully interactive public instance — writes only ever touch a working copy
# of the DB (never the pristine one); set to "1" to lock the instance down
MALDE_READ_ONLY = "0"

[[ports]]
localPort = 8137
externalPort = 80

[deployment]
run = ["python3", "malde/app/server.py"]
deploymentTarget = "cloudrun"

[nix]
channel = "stable-25_05"
packages = ["glibcLocales"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python3 malde/app/server.py"
waitForPort = 8137
